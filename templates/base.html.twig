<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EventHub — ISSAT Sousse{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0f1a;
            --bg2: #0f1829;
            --card: #131e30;
            --card2: #1a2740;
            --accent: #00d4aa;
            --accent2: #00a8ff;
            --gold: #f0b429;
            --text: #e2e8f0;
            --muted: #64748b;
            --border: rgba(0,212,170,0.15);
            --radius: 12px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }
        /* NAVBAR */
        nav {
            background: rgba(10,15,26,0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 64px;
        }
        .nav-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--accent);
            text-decoration: none;
            letter-spacing: -0.5px;
        }
        .nav-brand span { color: var(--gold); }
        .nav-links { display: flex; align-items: center; gap: 0.5rem; }
        .nav-links a {
            color: var(--muted);
            text-decoration: none;
            padding: 0.45rem 1rem;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
        }
        .nav-links a:hover { color: var(--text); background: var(--card); }
        .nav-links a.active { color: var(--accent); background: rgba(0,212,170,0.08); }
        .btn-nav {
            background: var(--accent);
            color: #0a0f1a !important;
            padding: 0.45rem 1.2rem !important;
            font-weight: 600 !important;
        }
        .btn-nav:hover { background: #00b894 !important; color: #0a0f1a !important; }
        /* FLASH MESSAGES */
        .flash-container { max-width: 1100px; margin: 1.5rem auto 0; padding: 0 2rem; }
        .flash {
            padding: 1rem 1.5rem;
            border-radius: var(--radius);
            margin-bottom: 0.75rem;
            font-size: 0.9rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .flash-success { background: rgba(0,212,170,0.1); border: 1px solid rgba(0,212,170,0.3); color: var(--accent); }
        .flash-error   { background: rgba(239,68,68,0.1);  border: 1px solid rgba(239,68,68,0.3);  color: #f87171; }
        .flash-info    { background: rgba(0,168,255,0.1);  border: 1px solid rgba(0,168,255,0.3);  color: var(--accent2); }
        /* MAIN */
        main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 2rem; }
        /* FOOTER */
        footer {
            border-top: 1px solid var(--border);
            text-align: center;
            padding: 2rem;
            color: var(--muted);
            font-size: 0.85rem;
            margin-top: 4rem;
        }
        footer a { color: var(--accent); text-decoration: none; }
        /* CARDS */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,212,170,0.1); }
        /* BUTTONS */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.65rem 1.5rem;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            border: none;
            transition: all 0.2s;
        }
        .btn-primary { background: var(--accent); color: #0a0f1a; }
        .btn-primary:hover { background: #00b894; }
        .btn-secondary { background: transparent; color: var(--accent); border: 1px solid var(--accent); }
        .btn-secondary:hover { background: rgba(0,212,170,0.08); }
        .btn-danger { background: #ef4444; color: white; }
        .btn-danger:hover { background: #dc2626; }
        /* FORM */
        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
        .form-control {
            width: 100%;
            background: var(--bg2);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.95rem;
            font-family: inherit;
            transition: border-color 0.2s;
        }
        .form-control:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,212,170,0.1); }
        .form-control::placeholder { color: var(--muted); }
        /* BADGE */
        .badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .badge-success { background: rgba(0,212,170,0.15); color: var(--accent); }
        .badge-danger  { background: rgba(239,68,68,0.15);  color: #f87171; }
        .badge-warning { background: rgba(240,180,41,0.15); color: var(--gold); }
        /* PAGE HEADER */
        .page-header {
            margin-bottom: 2.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--border);
        }
        .page-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 0.5rem;
        }
        .page-header p { color: var(--muted); font-size: 1rem; }
        /* TABLE */
        table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        th {
            text-align: left;
            padding: 0.85rem 1rem;
            background: var(--bg2);
            color: var(--muted);
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border);
        }
        td {
            padding: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            vertical-align: middle;
        }
        tr:hover td { background: rgba(255,255,255,0.02); }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
<nav>
    <a href="{{ path('app_home') }}" class="nav-brand">Event<span>Hub</span></a>
    <div class="nav-links">
        <a href="{{ path('app_events') }}" {% if app.request.get('_route') starts with 'app_event' %}class="active"{% endif %}>Événements</a>
        {% if app.user %}
            <a href="{{ path('app_logout') }}">Déconnexion</a>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_dashboard') }}" class="btn-nav btn">Admin</a>
            {% endif %}
        {% else %}
            <a href="{{ path('app_login') }}">Connexion</a>
            <a href="{{ path('app_register') }}" class="btn-nav btn">S'inscrire</a>
        {% endif %}
    </div>
</nav>

<div class="flash-container">
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">✓ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">✕ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('info') %}
        <div class="flash flash-info">ℹ {{ message }}</div>
    {% endfor %}
</div>

<main>{% block content %}{% endblock %}</main>

<footer>
    <p>© 2026 EventHub — ISSAT Sousse · Département Informatique · FIA3-GL &nbsp;|&nbsp;
    <a href="{{ path('admin_login') }}">Espace Admin</a></p>
</footer>
{% block javascripts %}{% endblock %}
</body>
</html>
