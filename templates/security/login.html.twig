{% extends 'base.html.twig' %}
{% block title %}Connexion — EventHub{% endblock %}
{% block content %}
<div style="max-width:420px;margin:2rem auto">
    <div style="text-align:center;margin-bottom:2rem">
        <h1 style="font-family:'Playfair Display',serif;font-size:1.8rem;margin-bottom:0.5rem">Connexion</h1>
        <p style="color:var(--muted);font-size:0.9rem">Accédez à votre espace EventHub</p>
    </div>

    <div class="card" style="padding:2rem">
        {% if error %}
            <div class="flash flash-error" style="margin-bottom:1.5rem">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <div class="form-group">
                <label>Nom d'utilisateur</label>
                <input type="text" name="username" value="{{ last_username }}" class="form-control" placeholder="Votre nom d'utilisateur" required autofocus>
            </div>
            <div class="form-group">
                <label>Mot de passe</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:0.9rem;font-size:1rem">
                Connexion →
            </button>
        </form>

        <div style="display:flex;align-items:center;gap:1rem;margin:1.5rem 0">
            <div style="flex:1;height:1px;background:var(--border)"></div>
            <span style="color:var(--muted);font-size:0.8rem">ou</span>
            <div style="flex:1;height:1px;background:var(--border)"></div>
        </div>

        <!-- PASSKEY LOGIN -->
        <button id="passkeyLoginBtn" class="btn btn-secondary" style="width:100%;justify-content:center;padding:0.9rem">
            🔑 Se connecter avec une Passkey
        </button>
        <p id="passkeyStatus" style="text-align:center;font-size:0.82rem;color:var(--muted);margin-top:0.75rem;display:none"></p>
    </div>

    <p style="text-align:center;margin-top:1.5rem;color:var(--muted);font-size:0.9rem">
        Pas encore de compte ? <a href="{{ path('app_register') }}" style="color:var(--accent)">S'inscrire</a>
    </p>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.getElementById('passkeyLoginBtn').addEventListener('click', async () => {
    const btn = document.getElementById('passkeyLoginBtn');
    const status = document.getElementById('passkeyStatus');
    status.style.display = 'block';

    if (!window.PublicKeyCredential) {
        status.textContent = '⚠ Votre navigateur ne supporte pas les Passkeys.';
        status.style.color = '#f87171';
        return;
    }

    try {
        btn.disabled = true;
        status.textContent = '⏳ Récupération du challenge...';

        // Step 1: Get authentication options
        const optRes = await fetch('/api/passkey/authenticate/options', { method: 'POST', headers: {'Content-Type': 'application/json'} });
        const { options } = await optRes.json();

        status.textContent = '🔑 Authentification en cours...';

        // Step 2: Use WebAuthn API
        const credential = await navigator.credentials.get({
            publicKey: {
                challenge: Uint8Array.from(atob(options.challenge), c => c.charCodeAt(0)),
                rpId: options.rpId,
                timeout: options.timeout,
                userVerification: options.userVerification,
            }
        });

        // Step 3: Verify with server
        const verifyRes = await fetch('/api/passkey/authenticate/verify', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                id: credential.id,
                rawId: btoa(String.fromCharCode(...new Uint8Array(credential.rawId))),
                type: credential.type,
                response: {
                    authenticatorData: btoa(String.fromCharCode(...new Uint8Array(credential.response.authenticatorData))),
                    clientDataJSON: btoa(String.fromCharCode(...new Uint8Array(credential.response.clientDataJSON))),
                    signature: btoa(String.fromCharCode(...new Uint8Array(credential.response.signature))),
                }
            })
        });

        const result = await verifyRes.json();
        if (result.success) {
            status.textContent = '✓ Authentification réussie !';
            status.style.color = 'var(--accent)';
            setTimeout(() => window.location.href = '/events', 1000);
        } else {
            throw new Error(result.error || 'Échec de l\'authentification');
        }
    } catch (e) {
        status.textContent = '✕ ' + (e.message || 'Erreur lors de l\'authentification');
        status.style.color = '#f87171';
        btn.disabled = false;
    }
});
</script>
{% endblock %}
