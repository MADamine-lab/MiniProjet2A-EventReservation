{% extends 'base.html.twig' %}
{% block title %}Renvoyer l'email de vérification{% endblock %}
{% block content %}
<div style="max-width:420px;margin:3rem auto;text-align:center">
    <div style="font-size:3rem;margin-bottom:1rem">📧</div>
    <h1 style="font-family:'Playfair Display',serif;font-size:1.6rem;margin-bottom:0.75rem">Renvoyer l'email</h1>
    <p style="color:var(--muted);margin-bottom:2rem">Entrez votre adresse email pour recevoir un nouveau lien de vérification.</p>

    <div class="card" style="padding:2rem;text-align:left">
        <form method="post">
            <div class="form-group">
                <label style="font-size:0.8rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Email</label>
                <input type="email" name="email" class="form-control" placeholder="votre@email.com" required style="margin-top:0.4rem">
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:0.9rem;margin-top:0.5rem">
                📤 Renvoyer le lien
            </button>
        </form>
    </div>

    <p style="margin-top:1.5rem;color:var(--muted);font-size:0.85rem">
        <a href="{{ path('app_login') }}" style="color:var(--accent)">← Retour à la connexion</a>
    </p>
</div>
{% endblock %}
