{% extends 'admin/base_admin.html.twig' %}
{% block title %}Modifier — {{ event.title }} — Admin{% endblock %}
{% block page_title %}✏️ Modifier l'événement{% endblock %}

{% block body %}
<div class="breadcrumb">
    <a href="{{ path('admin_events') }}">🎪 Événements</a>
    <span>›</span>
    <span>{{ event.title|slice(0,40) }}</span>
</div>

<div class="card" style="max-width:680px">
    <div class="card-header">
        <h2>Modifier : {{ event.title|slice(0,45) }}{% if event.title|length > 45 %}…{% endif %}</h2>
        <div class="flex gap-2">
            <a href="{{ path('admin_event_reservations', {id: event.id}) }}" class="btn btn-outline btn-sm">📋 Voir réservations</a>
        </div>
    </div>
    <div class="card-body">
        {% if event.image %}
        <div style="margin-bottom:1.25rem">
            <p style="font-size:0.75rem;color:var(--muted);margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.06em;font-weight:600">Image actuelle</p>
            <img src="/uploads/events/{{ event.image }}" style="height:120px;border-radius:10px;object-fit:cover;border:1px solid var(--border)" alt="">
        </div>
        {% endif %}

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

        <div class="form-group">
            {{ form_label(form.title) }}
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
        </div>

        <div class="form-group">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {'attr': {'rows': 5}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group">
                {{ form_label(form.date) }}
                {{ form_widget(form.date) }}
                {{ form_errors(form.date) }}
            </div>
            <div class="form-group">
                {{ form_label(form.seats) }}
                {{ form_widget(form.seats) }}
                {{ form_errors(form.seats) }}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.location) }}
            {{ form_widget(form.location) }}
            {{ form_errors(form.location) }}
        </div>

        <div class="form-group">
            {{ form_label(form.imageFile) }}
            {{ form_widget(form.imageFile) }}
            {{ form_errors(form.imageFile) }}
            <p style="font-size:0.75rem;color:var(--muted);margin-top:0.3rem">Laisser vide pour conserver l'image actuelle.</p>
        </div>

        <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
            <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
            <a href="{{ path('admin_events') }}" class="btn btn-outline">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
