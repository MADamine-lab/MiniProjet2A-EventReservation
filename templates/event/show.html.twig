{% extends 'base.html.twig' %}
{% block title %}{{ event.title }} — EventHub{% endblock %}
{% block content %}
<div style="margin-bottom:1.5rem">
    <a href="{{ path('app_events') }}" style="color:var(--muted);text-decoration:none;font-size:0.9rem">← Retour aux événements</a>
</div>

<div style="display:grid;grid-template-columns:1fr 340px;gap:2rem;align-items:start">
    <div>
        <div style="height:320px;background:linear-gradient(135deg,var(--card2) 0%,#1e3050 100%);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:5rem;overflow:hidden;margin-bottom:2rem;border:1px solid var(--border)">
            {% if event.image %}
                <img src="/uploads/events/{{ event.image }}" style="width:100%;height:100%;object-fit:cover" alt="{{ event.title }}">
            {% else %}🎪{% endif %}
        </div>

        <h1 style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;margin-bottom:1rem">{{ event.title }}</h1>

        <div style="display:flex;flex-wrap:wrap;gap:1.5rem;margin-bottom:2rem">
            <div style="display:flex;align-items:center;gap:0.5rem;color:var(--muted);font-size:0.9rem">
                <span style="font-size:1.1rem">📅</span>
                <div>
                    <div style="color:var(--text);font-weight:600">{{ event.date|date('d/m/Y')|capitalize }}</div>
                    <div>{{ event.date|date('H:i') }}</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;color:var(--muted);font-size:0.9rem">
                <span style="font-size:1.1rem">📍</span>
                <div>
                    <div style="color:var(--text);font-weight:600">{{ event.location }}</div>
                    <div>Lieu de l'événement</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;color:var(--muted);font-size:0.9rem">
                <span style="font-size:1.1rem">🎟</span>
                <div>
                    <div style="color:var(--text);font-weight:600">{{ event.seats }} places au total</div>
                    <div>{{ event.availableSeats }} disponibles</div>
                </div>
            </div>
        </div>

        <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem">
            <h2 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:1rem;color:var(--accent)">Description</h2>
            <p style="line-height:1.8;color:var(--muted);white-space:pre-wrap">{{ event.description }}</p>
        </div>
    </div>

    <div style="position:sticky;top:80px">
        <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem">
            <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:1.5rem">Réserver une place</h3>

            {% set avail = event.availableSeats %}
            <div style="margin-bottom:1.5rem">
                <div style="display:flex;justify-content:space-between;margin-bottom:0.5rem;font-size:0.85rem">
                    <span style="color:var(--muted)">Places restantes</span>
                    <span style="font-weight:600;color:{% if avail > 10 %}var(--accent){% elseif avail > 0 %}var(--gold){% else %}#f87171{% endif %}">
                        {{ avail }} / {{ event.seats }}
                    </span>
                </div>
                <div style="background:var(--bg2);border-radius:20px;height:8px;overflow:hidden">
                    <div style="height:100%;width:{{ ((event.seats - avail) / event.seats * 100)|round }}%;background:{% if avail > 10 %}var(--accent){% elseif avail > 0 %}var(--gold){% else %}#ef4444{% endif %};border-radius:20px;transition:width 0.5s"></div>
                </div>
            </div>

            {% if avail > 0 %}
                <a href="{{ path('app_event_reserve', {id: event.id}) }}" class="btn btn-primary" style="width:100%;justify-content:center;font-size:1rem;padding:1rem">
                    🎟 Réserver maintenant
                </a>
                <p style="text-align:center;font-size:0.8rem;color:var(--muted);margin-top:1rem">Réservation gratuite · Confirmation immédiate</p>
            {% else %}
                <button class="btn" style="width:100%;justify-content:center;background:var(--card2);color:var(--muted);cursor:not-allowed" disabled>
                    ❌ Événement complet
                </button>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
