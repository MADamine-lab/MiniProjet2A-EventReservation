{% extends 'base.html.twig' %}
{% block title %}Réserver — {{ event.title }}{% endblock %}
{% block content %}
<div style="margin-bottom:1.5rem">
    <a href="{{ path('app_event_show', {id: event.id}) }}" style="color:var(--muted);text-decoration:none;font-size:0.9rem">← Retour à l'événement</a>
</div>

<div style="max-width:600px;margin:0 auto">
    <div style="background:var(--card2);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:2rem;display:flex;gap:1rem;align-items:center">
        <span style="font-size:1.5rem">🎪</span>
        <div>
            <div style="font-weight:600;font-size:0.95rem">{{ event.title }}</div>
            <div style="color:var(--muted);font-size:0.82rem">{{ event.date|date('d/m/Y à H:i') }} · {{ event.location }}</div>
        </div>
        <span class="badge badge-success" style="margin-left:auto">{{ event.availableSeats }} places dispo.</span>
    </div>

    <div class="card" style="padding:2rem">
        <h2 style="font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:0.5rem">Vos informations</h2>
        <p style="color:var(--muted);font-size:0.9rem;margin-bottom:2rem">Remplissez le formulaire pour confirmer votre réservation.</p>

        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
            {% for error in form.vars.errors %}
                <div class="flash flash-error" style="margin-bottom:1rem">{{ error.message }}</div>
            {% endfor %}

            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {% if form.name.vars.errors|length %}
                    <span style="color:#f87171;font-size:0.8rem">{{ form_errors(form.name) }}</span>
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                {% if form.email.vars.errors|length %}
                    <span style="color:#f87171;font-size:0.8rem">{{ form_errors(form.email) }}</span>
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.phone) }}
                {{ form_widget(form.phone) }}
                {% if form.phone.vars.errors|length %}
                    <span style="color:#f87171;font-size:0.8rem">{{ form_errors(form.phone) }}</span>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:1rem;font-size:1rem;margin-top:1rem">
                ✓ Confirmer la réservation
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
