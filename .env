APP_ENV=dev
APP_SECRET=your_app_secret_change_this_in_production
DATABASE_URL="mysql://root:root@db:3306/event_reservation?serverVersion=8.0&charset=utf8mb4"
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_jwt_passphrase
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

###> symfony/mailer ###
# Pour tester en local avec Mailpit (interface web sur port 8025)
MAILER_DSN=smtp://mailpit:1025
